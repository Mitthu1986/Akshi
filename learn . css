/* learn.css */

/* Background: Black and Simple text in White */
body {
    background-color: #000000;
    color: #ffffff;
    font-family: 'Segoe UI', Tahoma, sans-serif;
    margin: 0;
    padding: 0;
}

/* Akshi in Green #99ff00 with top spacing */
header {
    padding-top: 80px;
    text-align: center;
}

header h1 {
    color: #99ff00;
    font-size: 3rem;
    letter-spacing: 10px;
    margin-bottom: 5px;
}

/* Sub-text/Tagline in white */
header p {
    color: #ffffff;
    font-style: italic;
    opacity: 0.8;
}

hr {
    border: 0;
    border-top: 1px solid #333;
    margin: 20px 0;
}

/* Main Content Section */
main {
    text-align: center;
    padding: 20px;
}

/* Heading Blue #00ffff */
h2, h3 {
    color: #00ffff;
    text-transform: uppercase;
    letter-spacing: 2px;
}

/* Simple text in White */
p, label {
    color: #ffffff;
}

/* Button Yellow #eeff00 */
button, input[type="submit"] {
    background-color: #eeff00;
    color: #000000; /* Black text on yellow button for readability */
    border: none;
    padding: 10px 25px;
    font-weight: bold;
    border-radius: 5px;
    cursor: pointer;
    margin-top: 15px;
    transition: 0.3s;
}

button:hover {
    background-color: #ccff00;
    transform: scale(1.05);
}

/* Video Player Styling */
video {
    border: 2px solid #00ffff; /* Blue border to match headings */
    border-radius: 10px;
    margin: 20px 0;
    box-shadow: 0 0 15px rgba(0, 255, 255, 0.3);
}

/* Link color */
a {
    color: #eeff00;
    text-decoration: none;
}

a:hover {
    text-decoration: underline;
}